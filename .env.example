# ── LLM ──────────────────────────
# LLM_PROVIDER = openai | gemini | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Search ───────────────────────
# SEARCH_PROVIDER = serpapi | serper | google | duckduckgo
SEARCH_PROVIDER=serpapi
SERPAPI_KEY=...

# ── Database (Supabase Postgres) ──
# From your Supabase project: Project Settings → Database → Connection string.
# Use the POOLED "Transaction mode" URI (port 6543), not the direct one (5432) —
# it's safer against the free tier's connection limits. Paste it exactly as
# Supabase generates it; don't hand-assemble sslmode/pooler params.
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres
